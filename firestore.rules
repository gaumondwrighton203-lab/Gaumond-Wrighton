rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global safety net: default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Validation helper
    function isValidTariff(data) {
      return data.coldWaterRate is number &&
             data.hotWaterRate is number &&
             data.electricityRate is number &&
             data.electricityTariffType is string &&
             data.electricityTariffType in ['single', 'double', 'triple'] &&
             data.currency is string &&
             data.currency.size() <= 10;
    }

    match /users/{userId} {
      allow get: if request.auth != null && request.auth.uid == userId;
      allow create, update: if request.auth != null && request.auth.uid == userId && isValidTariff(request.resource.data);
      allow delete: if false;
    }
  }
}
